from typing import List

# 这题和1143求最长公共子序列(LCS)思路非常像, 都是填二维数组, 只不过dp[i][j]的含义不一样
class Solution:
    def findLength(self, A: List[int], B: List[int]) -> int:
        lenA = len(A)
        lenB = len(B)
        dp = [[0] * lenB for _ in range(lenA)]
        max_len = 0
        i = 0
        while i < lenA:
            j = 0
            while j < lenB:
                if i == 0 or j == 0:
                    if A[i] == B[j]:
                        dp[i][j] = 1
                    else:
                        dp[i][j] = 0
                    j += 1
                    continue
                if A[i] == B[j]:
                    dp[i][j] = dp[i - 1][j - 1] + 1
                    max_len = max(dp[i][j], max_len)
                else:
                    dp[i][j] = 0
                j += 1
            i += 1
        return max_len

